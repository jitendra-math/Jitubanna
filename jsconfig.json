{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "$components/*": ["src/lib/components/*"],
      "$effects/*": ["src/lib/components/effects/*"],
      "$layout/*": ["src/lib/components/layout/*"],
      "$ui/*": ["src/lib/components/ui/*"],
      "$home/*": ["src/lib/components/home/*"],
      "$utils/*": ["src/lib/utils/*"],
      "$stores/*": ["src/lib/stores/*"],
      "$styles/*": ["src/lib/styles/*"]
    }
  },
  "include": [
    "src/**/*.js",
    "src/**/*.svelte"
  ]
}